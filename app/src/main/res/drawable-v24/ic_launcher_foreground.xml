<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground: GBG logo bitmap. Padding is baked into the source
  PNG (logo ~38% of canvas width, white background), so the launcher cannot
  rescale away the whitespace.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@drawable/gbg_logo"
    android:gravity="fill" />
